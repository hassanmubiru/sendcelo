{
  "name": "sendcelo",
  "version": "1.0.0",
  "description": "SendCelo - Autonomous agent for instant, low-cost cross-border remittances on Celo blockchain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "celo",
    "remittances",
    "micropayments",
    "agent",
    "stablecoin",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@celo/contractkit": "^5.2.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "axios": "^1.6.2",
    "decimal.js": "^10.4.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.2.3",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  }
}
